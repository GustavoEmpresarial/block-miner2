# =============================================================================
# Bloco de BACKUP para colar no .env da VPS (/root/block-miner/.env)
# Pré-requisito: rclone configurado no host com remote "gdrive" e pasta no Drive.
# Não commites este ficheiro com segredos; só copia as linhas para o servidor.
# =============================================================================

BACKUP_ENABLED=true
BACKUP_CRON=0 3 * * *
BACKUP_RUN_ON_STARTUP=true
BACKUP_STARTUP_DELAY_MS=60000

BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=7
BACKUP_FILENAME_PREFIX=blockminer-db-
BACKUP_PG_GZIP=true

# Segunda cópia em disco (só se montares um path real no container)
BACKUP_EXTERNAL_ENABLED=false
BACKUP_EXTERNAL_DIR=/mnt/external-backups/blockminer
BACKUP_EXTERNAL_RETENTION_DAYS=30

# Google Drive (rclone)
# Pré-requisito na VPS: rclone config no HOST em /root/.config/rclone (o compose monta no container).
# OAuth: o volume tem de ser RW (já está no docker-compose) para renovar token.
BACKUP_CLOUD_ENABLED=true
# Opção A — comando explícito (remote:nome ou remote:ID_pasta)
BACKUP_CLOUD_COMMAND=rclone copy "{backupFile}" "gdrive:COLAR_ID_DA_PASTA" --transfers 1 --checkers 1 --drive-chunk-size 32M --fast-list
# Opção B — só pasta (se BACKUP_CLOUD_COMMAND estiver vazio, o servidor monta o mesmo rclone copy)
# BACKUP_CLOUD_REMOTE=gdrive
# BACKUP_CLOUD_FOLDER_ID=COLAR_ID_DA_PASTA
BACKUP_CLOUD_TIMEOUT_MS=120000

# Só dump da BD no arranque; tar.gz de todo o site desligado (mais leve)
BACKUP_FULL_SITE_ON_STARTUP=false
BACKUP_FULL_SITE_STARTUP_DELAY_MS=15000
